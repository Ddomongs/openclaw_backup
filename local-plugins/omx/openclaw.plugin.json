{
  "id": "omx",
  "name": "OMX Bridge",
  "description": "Registers OpenClaw tools for the real oh-my-codex CLI (`omx`): status, hud, explore, exec, team, and ralph.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "command": {
        "type": "string",
        "default": "/opt/homebrew/bin/omx",
        "description": "Path or command name for the real oh-my-codex CLI."
      },
      "defaultTimeoutSeconds": {
        "type": "number",
        "minimum": 5,
        "maximum": 1800,
        "default": 120
      },
      "maxTimeoutSeconds": {
        "type": "number",
        "minimum": 30,
        "maximum": 7200,
        "default": 1800
      },
      "maxOutputChars": {
        "type": "number",
        "minimum": 1000,
        "maximum": 200000,
        "default": 60000
      }
    }
  }
}
